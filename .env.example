# Database (PostgreSQL — use Neon connection string in production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Clerk Authentication
# Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Admin access — email of the account allowed to use /admin routes.
# REQUIRED in Vercel Production/Preview env vars (Settings → Environment Variables).
# Must match a verified Clerk email for the admin account (primary or secondary).
ADMIN_EMAIL=risan_rahman@yahoo.com

# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public app URL used for Stripe redirect URLs and X OAuth callback fallbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Transactional email (Resend — https://resend.com)
# Purchase receipts are skipped gracefully when these are unset.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=SolePrompt <receipts@yourdomain.com>

# X (Twitter) API — OAuth 1.0a for admin social posting
# Create an app at https://developer.x.com with Read and write permissions.
# App keys (consumer credentials):
X_API_KEY=
X_API_SECRET=
# OAuth callbacks — must match URLs configured in the X developer portal exactly.
# When unset or invalid, defaults use getAppUrl() (NEXT_PUBLIC_APP_URL → VERCEL_URL → production domain).
# Production (getsoleprompt.com):
X_CALLBACK_URL=https://getsoleprompt.com/api/admin/social/x/callback
X_BUYER_CALLBACK_URL=https://getsoleprompt.com/api/buyer/scrubber/x/callback
X_SOCIAL_CALLBACK_URL=https://getsoleprompt.com/api/buyer/social/x/callback
# Optional legacy fallback if you connect via env vars instead of in-app OAuth:
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Meta (Facebook & Instagram) — OAuth 2.0 for buyer social tools
# Create an app at https://developers.facebook.com with Facebook Login product.
# FB and IG share one Meta app; register separate redirect URIs per platform.
META_APP_ID=
META_APP_SECRET=
META_FACEBOOK_CALLBACK_URL=https://getsoleprompt.com/api/buyer/social-tools/facebook/callback
META_INSTAGRAM_CALLBACK_URL=https://getsoleprompt.com/api/buyer/social-tools/instagram/callback

# LinkedIn — OAuth 2.0 for buyer social tools
# Create an app at https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://getsoleprompt.com/api/buyer/social-tools/linkedin/callback

# Optional: protect /api/cron/social for Vercel Cron
CRON_SECRET=

# SolePrompt Studio — AI YouTube package generation (OpenAI)
OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=

# Studio production queue worker (optional — inline worker runs on project create)
# Schedule GET /api/cron/studio with Authorization: Bearer $CRON_SECRET
