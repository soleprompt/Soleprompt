generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  buyer
  seller
  admin
}

enum PromptStatus {
  draft
  review
  published
  rejected
}

enum PromptDifficulty {
  beginner
  intermediate
  advanced
}

enum PurchaseStatus {
  pending
  completed
  refunded
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum CreatorStatus {
  pending
  approved
  rejected
  suspended
}

enum AffiliateStatus {
  pending
  approved
  rejected
  suspended
}

enum PayoutStatus {
  pending
  approved
  paid
  rejected
}

enum PayoutKind {
  creator
  affiliate
}

enum SocialPlatform {
  x
  facebook
  instagram
  linkedin
}

enum SocialPostStatus {
  draft
  approved
  scheduled
  posted
  failed
}

model User {
  id                    String    @id @default(cuid())
  clerkUserId           String    @unique
  username              String
  email                 String
  role                  UserRole  @default(buyer)
  onboardingDismissedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  sellerProfile       SellerProfile?
  prompts             Prompt[]       @relation("SellerPrompts")
  purchases           Purchase[]     @relation("BuyerPurchases")
  buyerTransactions   Transaction[]  @relation("BuyerTransactions")
  sellerTransactions  Transaction[]  @relation("SellerTransactions")
  auditLogs           AuditLog[]
  reviews             Review[]
  wishlist            Wishlist[]
  promptViews         PromptView[]
  toolVisits          ToolVisit[]
  clickThroughs       ClickThrough[]
  xConnections        XConnection[]
  socialConnections   SocialConnection[]
  payoutRequests      PayoutRequest[]
  affiliate           Affiliate?
  youtubePackages     YouTubePackage[]
  studioProjects      StudioProject[]
  studioResearch      StudioResearch[]
  studioSubscription  StudioSubscription?
}

model XConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  accessSecret String
  screenName   String
  xUserId      String
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([connectedAt])
}

model SocialConnection {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       SocialPlatform
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  displayName    String
  platformUserId String
  connectedAt    DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, platform])
  @@index([connectedAt])
}

model SellerProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String
  bio                String?
  salesCount         Int           @default(0)
  freeDownloadCount  Int           @default(0)
  totalEarnings      Float         @default(0)
  creatorStatus      CreatorStatus @default(approved)
  verified           Boolean       @default(false)
  verifiedAt         DateTime?
  payoutEmail        String?
  payoutMethod       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  prompts     Prompt[]
  createdAt   DateTime @default(now())
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  prompts PromptTag[]
}

model Prompt {
  id               String       @id @default(cuid())
  title            String
  description      String
  content          String
  preview          String
  compatibleModels   String[]
  sampleOutput       String
  difficulty         PromptDifficulty @default(beginner)
  estimatedTimeSaved String?
  coverImageUrl      String?
  price              Float
  status             PromptStatus @default(draft)
  featured    Boolean      @default(false)
  views       Int          @default(0)
  sellerId    String
  seller      User         @relation("SellerPrompts", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  tags        PromptTag[]
  purchases    Purchase[]
  transactions Transaction[]
  reviews      Review[]
  wishlist     Wishlist[]
  promptViews  PromptView[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model Purchase {
  id          String         @id @default(cuid())
  promptId    String
  prompt      Prompt         @relation(fields: [promptId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User           @relation("BuyerPurchases", fields: [buyerId], references: [id], onDelete: Cascade)
  amount      Float
  status      PurchaseStatus @default(completed)
  transaction Transaction?
  createdAt   DateTime       @default(now())
}

model Transaction {
  id                  String            @id @default(cuid())
  purchaseId          String            @unique
  purchase            Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stripeSessionId     String?           @unique
  stripePaymentId     String?           @unique
  currency            String            @default("usd")
  amount              Float
  creatorShare        Float             @default(0)
  platformFee         Float             @default(0)
  affiliateCommission Float             @default(0)
  affiliateId         String?
  affiliate           Affiliate?        @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  referralCode        String?
  status              TransactionStatus @default(completed)
  buyerId             String
  buyer               User              @relation("BuyerTransactions", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId            String
  seller              User              @relation("SellerTransactions", fields: [sellerId], references: [id], onDelete: Cascade)
  promptId            String
  prompt              Prompt            @relation(fields: [promptId], references: [id], onDelete: Cascade)
  affiliateReferral   AffiliateReferral?
  createdAt           DateTime          @default(now())

  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
  @@index([affiliateId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([promptId, userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, promptId])
}

model PromptView {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId String
  prompt   Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@index([userId, viewedAt])
}

model ToolVisit {
  id           String   @id @default(cuid())
  toolSlug       String
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  utmSource      String?
  utmCampaign    String?
  visitedAt      DateTime @default(now())

  @@index([toolSlug, visitedAt])
  @@index([utmSource, visitedAt])
}

model ClickThrough {
  id        String   @id @default(cuid())
  eventType String
  targetKey String
  metadata  Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clickedAt DateTime @default(now())

  @@index([eventType, targetKey, clickedAt])
}

model SocialPost {
  id          String           @id @default(cuid())
  platform    SocialPlatform   @default(x)
  content     String
  status      SocialPostStatus @default(draft)
  scheduledAt DateTime?
  postedAt    DateTime?
  xPostId     String?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, scheduledAt])
}

model EngageTargetAccount {
  id        String   @id @default(cuid())
  username  String   @unique
  xUserId   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts EngagePost[]
}

model EngagePost {
  id              String              @id @default(cuid())
  targetAccountId String
  targetAccount   EngageTargetAccount @relation(fields: [targetAccountId], references: [id], onDelete: Cascade)
  xTweetId        String              @unique
  authorUsername  String
  tweetText       String
  tweetUrl        String
  tweetedAt       DateTime
  relevanceScore  Int                 @default(0)
  matchedTopics   String[]
  likeCount       Int                 @default(0)
  replyCount      Int                 @default(0)
  retweetCount    Int                 @default(0)
  scannedAt       DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  drafts EngageReplyDraft[]

  @@index([targetAccountId, tweetedAt])
  @@index([relevanceScore])
}

model EngageReplyDraft {
  id           String           @id @default(cuid())
  postId       String
  post         EngagePost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  style        String
  content      String
  status       SocialPostStatus @default(draft)
  includesLink Boolean          @default(false)
  taglineKey   String?
  postedAt     DateTime?
  xReplyId     String?
  error        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([postId])
  @@index([status])
}

model PlatformSettings {
  id                         String   @id @default("default")
  creatorCommissionPercent   Float    @default(70)
  affiliateCommissionPercent Float    @default(10)
  minPayoutAmount            Float    @default(25)
  updatedAt                  DateTime @updatedAt
}

model PayoutRequest {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          PayoutKind
  amount        Float
  status        PayoutStatus @default(pending)
  payoutEmail   String?
  payoutMethod  String?
  note          String?
  adminNote     String?
  processedAt   DateTime?
  processedById String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, kind, status])
  @@index([status, createdAt])
}

model Affiliate {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  code             String          @unique
  status           AffiliateStatus @default(pending)
  totalClicks      Int             @default(0)
  totalConversions Int             @default(0)
  totalEarnings    Float           @default(0)
  pendingBalance   Float           @default(0)
  paidBalance      Float           @default(0)
  payoutEmail      String?
  payoutMethod     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  clicks      ReferralClick[]
  referrals   AffiliateReferral[]
  transactions Transaction[]
}

model ReferralClick {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  landingPath String?
  referrerCode String
  createdAt   DateTime  @default(now())

  @@index([affiliateId, createdAt])
}

model AffiliateReferral {
  id            String       @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  purchaseId    String?
  commission    Float
  status        PayoutStatus @default(pending)
  createdAt     DateTime     @default(now())

  @@index([affiliateId, createdAt])
}

model YouTubePackage {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          String
  niche          String?
  videoType      String
  tone           String?
  titles         Json
  script         String   @db.Text
  hook           String   @db.Text
  intro          String   @db.Text
  mainSections   Json
  outro          String   @db.Text
  callToAction   String   @db.Text
  description    String   @db.Text
  tags           Json
  thumbnailIdeas Json
  pinnedComment  String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studioProject  StudioProject?

  @@index([userId, createdAt])
}

enum StudioProjectStatus {
  queued
  researching
  writing
  storyboarding
  storyboard_complete
  generating_assets
  creating_voice
  rendering_video
  completed
  failed
  cancelled
}

enum StudioJobStatus {
  pending
  processing
  completed
  failed
}

enum StudioLogLevel {
  info
  warn
  error
  debug
}

enum StudioAssetType {
  image
  video_clip
  audio
  graphic
  b_roll
  other
}

enum StudioUploadStatus {
  pending
  uploading
  completed
  failed
}

model StudioProject {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic                 String
  niche                 String?
  videoType             String
  tone                  String?
  status                StudioProjectStatus @default(queued)
  currentStep           String?
  progressPercent       Int                 @default(0)
  estimatedCompletionAt DateTime?
  error                 String?             @db.Text
  startedAt             DateTime?
  completedAt           DateTime?
  packageId             String?             @unique
  package               YouTubePackage?     @relation(fields: [packageId], references: [id], onDelete: SetNull)
  metadata              Json?

  scenes     StudioScene[]
  assets     StudioAsset[]
  voiceovers StudioVoiceover[]
  videos     StudioVideo[]
  thumbnails StudioThumbnail[]
  uploads    StudioUpload[]
  analytics  StudioAnalytics[]
  logs       StudioProjectLog[]
  jobs       StudioJob[]
  research   StudioResearch?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model StudioProjectLog {
  id        String           @id @default(cuid())
  projectId String
  project   StudioProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  level     StudioLogLevel   @default(info)
  step      String?
  message   String           @db.Text
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([projectId, createdAt])
}

model StudioJob {
  id          String          @id @default(cuid())
  projectId   String
  project     StudioProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  step        String
  status      StudioJobStatus @default(pending)
  priority    Int             @default(0)
  attempts    Int             @default(0)
  maxAttempts Int             @default(3)
  payload     Json?
  result      Json?
  error       String?         @db.Text
  scheduledAt DateTime        @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  lockedAt    DateTime?
  lockedBy    String?

  @@index([status, scheduledAt])
  @@index([projectId, step])
}

model StudioScene {
  id          String   @id @default(cuid())
  projectId   String
  project     StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orderIndex  Int
  title       String
  description String   @db.Text
  script      String?  @db.Text
  durationSec Int?
  visualNotes String?  @db.Text
  narration           String? @db.Text
  onScreenText        String? @db.Text
  visualDescription   String? @db.Text
  cameraMovement      String?
  bRollRecommendation String? @db.Text
  aiImagePrompt       String? @db.Text
  aiVideoPrompt       String? @db.Text
  soundEffects        String?
  backgroundMusicMood String?
  transitionType      String?
  captionText         String? @db.Text
  metadata    Json?

  assets    StudioAsset[]
  voiceover StudioVoiceover?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, orderIndex])
}

model StudioAsset {
  id        String          @id @default(cuid())
  projectId String
  project   StudioProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneId   String?
  scene     StudioScene?    @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  type      StudioAssetType
  name      String
  url       String?
  provider  String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sceneId])
}

model StudioVoiceover {
  id          String        @id @default(cuid())
  projectId   String
  project     StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneId     String?       @unique
  scene       StudioScene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  text        String        @db.Text
  audioUrl    String?
  provider    String?
  voiceId     String?
  durationSec Int?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model StudioVideo {
  id          String        @id @default(cuid())
  projectId   String
  project     StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      String        @default("pending")
  url         String?
  durationSec Int?
  provider    String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model StudioThumbnail {
  id        String        @id @default(cuid())
  projectId String
  project   StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  imageUrl  String?
  provider  String?
  metadata  Json?
  isPrimary Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model StudioUpload {
  id          String             @id @default(cuid())
  projectId   String
  project     StudioProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    String             @default("youtube")
  status      StudioUploadStatus @default(pending)
  externalId  String?
  externalUrl String?
  error       String?            @db.Text
  metadata    Json?
  uploadedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model StudioAnalytics {
  id           String        @id @default(cuid())
  projectId    String
  project      StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  views        Int           @default(0)
  likes        Int           @default(0)
  comments     Int           @default(0)
  watchTimeSec Int           @default(0)
  ctr          Float?
  metadata     Json?
  fetchedAt    DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, fetchedAt])
}

enum StudioResearchStatus {
  queued
  researching
  completed
  failed
}

model StudioResearch {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?              @unique
  project   StudioProject?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  topic     String
  niche     String?
  videoType String?
  tone      String?

  status    StudioResearchStatus @default(queued)
  error     String?              @db.Text

  targetAudience         String? @db.Text
  searchIntent           String? @db.Text
  competitorChannels     Json?
  trendingVideoAngles    Json?
  viralHooks             Json?
  keywordClusters        Json?
  longTailKeywords       Json?
  questionsPeopleAsk     Json?
  emotionalTriggers      Json?
  thumbnailPsychology    Json?
  viewerObjections       Json?
  retentionOpportunities Json?
  suggestedCta           String? @db.Text
  monetizationIdeas      Json?
  affiliateOpportunities Json?

  provider    String?
  model       String?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SocialReply {
  id                String           @id @default(cuid())
  platform          SocialPlatform   @default(x)
  targetTweetId     String
  targetTweetUrl    String?
  targetAuthor      String?
  targetSnippet     String?
  postSummary       String?
  replyStyle        String?
  parentBatchId     String?
  content           String
  status            SocialPostStatus @default(draft)
  includesLink      Boolean          @default(false)
  taglineKey        String?
  scheduledAt       DateTime?
  postedAt          DateTime?
  xReplyId          String?
  likeCount         Int?
  impressionCount   Int?
  replyCount        Int?
  profileVisitCount Int?
  followerGain      Int?
  metricsFetchedAt  DateTime?
  error             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, scheduledAt])
  @@index([targetTweetId])
  @@index([taglineKey])
  @@index([parentBatchId])
}

enum StudioSubscriptionTier {
  free
  creator
  pro
  agency
}

enum StudioSubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete
}

model StudioSubscription {
  id                   String                   @id @default(cuid())
  userId               String                   @unique
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 StudioSubscriptionTier   @default(free)
  status               StudioSubscriptionStatus @default(active)
  stripeCustomerId     String?                  @unique
  stripeSubscriptionId String?                  @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}
