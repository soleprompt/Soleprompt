generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  buyer
  seller
  admin
}

enum PromptStatus {
  draft
  review
  published
  rejected
}

enum PromptDifficulty {
  beginner
  intermediate
  advanced
}

enum PurchaseStatus {
  pending
  completed
  refunded
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum SocialPlatform {
  x
  facebook
  instagram
  linkedin
}

enum SocialPostStatus {
  draft
  approved
  scheduled
  posted
  failed
}

model User {
  id                    String    @id @default(cuid())
  clerkUserId           String    @unique
  username              String
  email                 String
  role                  UserRole  @default(buyer)
  onboardingDismissedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  sellerProfile       SellerProfile?
  prompts             Prompt[]       @relation("SellerPrompts")
  purchases           Purchase[]     @relation("BuyerPurchases")
  buyerTransactions   Transaction[]  @relation("BuyerTransactions")
  sellerTransactions  Transaction[]  @relation("SellerTransactions")
  auditLogs           AuditLog[]
  reviews             Review[]
  wishlist            Wishlist[]
  promptViews         PromptView[]
  toolVisits          ToolVisit[]
  clickThroughs       ClickThrough[]
  xConnections        XConnection[]
  socialConnections   SocialConnection[]
}

model XConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  accessSecret String
  screenName   String
  xUserId      String
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([connectedAt])
}

model SocialConnection {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       SocialPlatform
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  displayName    String
  platformUserId String
  connectedAt    DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, platform])
  @@index([connectedAt])
}

model SellerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String
  bio           String?
  salesCount         Int      @default(0)
  freeDownloadCount  Int      @default(0)
  totalEarnings      Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  prompts     Prompt[]
  createdAt   DateTime @default(now())
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  prompts PromptTag[]
}

model Prompt {
  id               String       @id @default(cuid())
  title            String
  description      String
  content          String
  preview          String
  compatibleModels   String[]
  sampleOutput       String
  difficulty         PromptDifficulty @default(beginner)
  estimatedTimeSaved String?
  coverImageUrl      String?
  price              Float
  status             PromptStatus @default(draft)
  featured    Boolean      @default(false)
  views       Int          @default(0)
  sellerId    String
  seller      User         @relation("SellerPrompts", fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  tags        PromptTag[]
  purchases    Purchase[]
  transactions Transaction[]
  reviews      Review[]
  wishlist     Wishlist[]
  promptViews  PromptView[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model Purchase {
  id          String         @id @default(cuid())
  promptId    String
  prompt      Prompt         @relation(fields: [promptId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User           @relation("BuyerPurchases", fields: [buyerId], references: [id], onDelete: Cascade)
  amount      Float
  status      PurchaseStatus @default(completed)
  transaction Transaction?
  createdAt   DateTime       @default(now())
}

model Transaction {
  id              String            @id @default(cuid())
  purchaseId      String            @unique
  purchase        Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stripeSessionId String?           @unique
  stripePaymentId String?           @unique
  currency        String            @default("usd")
  amount          Float
  status          TransactionStatus @default(completed)
  buyerId         String
  buyer           User              @relation("BuyerTransactions", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId        String
  seller          User              @relation("SellerTransactions", fields: [sellerId], references: [id], onDelete: Cascade)
  promptId        String
  prompt          Prompt            @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())

  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([promptId, userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, promptId])
}

model PromptView {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId String
  prompt   Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@index([userId, viewedAt])
}

model ToolVisit {
  id        String   @id @default(cuid())
  toolSlug  String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  visitedAt DateTime @default(now())

  @@index([toolSlug, visitedAt])
}

model ClickThrough {
  id        String   @id @default(cuid())
  eventType String
  targetKey String
  metadata  Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clickedAt DateTime @default(now())

  @@index([eventType, targetKey, clickedAt])
}

model SocialPost {
  id          String           @id @default(cuid())
  platform    SocialPlatform   @default(x)
  content     String
  status      SocialPostStatus @default(draft)
  scheduledAt DateTime?
  postedAt    DateTime?
  xPostId     String?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, scheduledAt])
}

model EngageTargetAccount {
  id        String   @id @default(cuid())
  username  String   @unique
  xUserId   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts EngagePost[]
}

model EngagePost {
  id              String              @id @default(cuid())
  targetAccountId String
  targetAccount   EngageTargetAccount @relation(fields: [targetAccountId], references: [id], onDelete: Cascade)
  xTweetId        String              @unique
  authorUsername  String
  tweetText       String
  tweetUrl        String
  tweetedAt       DateTime
  relevanceScore  Int                 @default(0)
  matchedTopics   String[]
  likeCount       Int                 @default(0)
  replyCount      Int                 @default(0)
  retweetCount    Int                 @default(0)
  scannedAt       DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  drafts EngageReplyDraft[]

  @@index([targetAccountId, tweetedAt])
  @@index([relevanceScore])
}

model EngageReplyDraft {
  id           String           @id @default(cuid())
  postId       String
  post         EngagePost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  style        String
  content      String
  status       SocialPostStatus @default(draft)
  includesLink Boolean          @default(false)
  taglineKey   String?
  postedAt     DateTime?
  xReplyId     String?
  error        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([postId])
  @@index([status])
}

model SocialReply {
  id                String           @id @default(cuid())
  platform          SocialPlatform   @default(x)
  targetTweetId     String
  targetTweetUrl    String?
  targetAuthor      String?
  targetSnippet     String?
  postSummary       String?
  replyStyle        String?
  parentBatchId     String?
  content           String
  status            SocialPostStatus @default(draft)
  includesLink      Boolean          @default(false)
  taglineKey        String?
  scheduledAt       DateTime?
  postedAt          DateTime?
  xReplyId          String?
  likeCount         Int?
  impressionCount   Int?
  replyCount        Int?
  profileVisitCount Int?
  followerGain      Int?
  metricsFetchedAt  DateTime?
  error             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, scheduledAt])
  @@index([targetTweetId])
  @@index([taglineKey])
  @@index([parentBatchId])
}
